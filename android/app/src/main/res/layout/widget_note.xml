<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0C"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HIZLI NOTLAR"
        android:textColor="#FFBB00"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginBottom="12dp" />

    <!-- Item 1 -->
    <LinearLayout
        android:id="@+id/widget_item_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="10dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_content_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Item 2 -->
    <LinearLayout
        android:id="@+id/widget_item_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_content_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kayıtlı not yok."
        android:textColor="#555555"
        android:textSize="13sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="8dp" />

</LinearLayout>
