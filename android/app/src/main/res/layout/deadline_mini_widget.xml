<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/deadline_widget_background"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_animation_frame"
        android:layout_width="60dp"
        android:layout_height="30dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:contentDescription="Azrail animasyonu" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_animation_frame"
        android:layout_alignTop="@id/widget_animation_frame"
        android:layout_marginStart="8dp"
        android:text="Deadline"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxEms="10"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_toEndOf="@id/widget_animation_frame"
        android:layout_marginStart="8dp"
        android:text="-- gün kaldı"
        android:textColor="#BE002A"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="4dp"
        android:progress="50"
        android:progressTint="#BE002A"
        android:progressBackgroundTint="#330000" />

</RelativeLayout>
